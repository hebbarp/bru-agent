# BRU Agent Configuration

# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Agent behavior
BRU_AUTONOMY=supervised          # full | supervised | cautious

# Matsya Connection (optional — BRU works standalone too)
# MATSYA_BASE_URL=https://your-matsya-instance.com
# MATSYA_API_KEY=your-matsya-api-key
# MATSYA_USER_ID=
# MATSYA_TENANT_ID=
# MATSYA_DEFAULT_WORKSPACE_ID=

# Email Channel (optional)
# BRU_EMAIL_ADDRESS=bru@company.com
# BRU_EMAIL_PASSWORD=app-password
# BRU_IMAP_SERVER=imap.gmail.com
# BRU_SMTP_SERVER=smtp.gmail.com

# Telegram Channel (optional)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
